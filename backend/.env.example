# Copy to `.env` in this directory for local development.

DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-only-change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite (default) or MySQL, e.g.:
# DATABASE_URL=mysql://user:pass@127.0.0.1:3306/scalelabs
DATABASE_URL=sqlite:///db.sqlite3

# Comma-separated origins for browser clients (Next.js on Vercel or local).
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=

# Frontend dev tunnel — ngrok http 3000 (browser UI). CORS only.
DEV_PUBLIC_ORIGIN=https://uniformless-bryleigh-sebacic.ngrok-free.dev

# Backend / Vapi webhooks — ngrok http 8000 or production API host.
# Required when frontend and API use different public URLs.
VAPI_WEBHOOK_BASE=https://surcharge-hydrogen-fanfare.ngrok-free.dev

# Fernet key for encrypting Notion tokens at rest (generate with cryptography.fernet.Fernet.generate_key())
FIELD_ENCRYPTION_KEY=

# Vapi server + webhooks — one platform key for all tenants (end users never see or supply this).
# Required for agent create/update, sync-vapi, workflows, chat proxy, etc.
# Optional: Redis for shared metrics cache across workers (default: in-process LocMem)
# REDIS_URL=redis://127.0.0.1:6379/1

VAPI_API_KEY=
VAPI_PUBLIC_KEY=
# Leave empty in local dev when DEV_PUBLIC_ORIGIN is your ngrok URL.
VAPI_WEBHOOK_BASE=
VAPI_SHARED_SECRET=

