{
  "name": "scale-labs",
  "private": true,
  "scripts": {
    "predev": "node scripts/kill-dev-ports.js",
    "dev": "concurrently --kill-others-on-fail -n django,next -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node scripts/run-backend.js",
    "dev:frontend": "npm run dev --prefix frontend -- --hostname 0.0.0.0 --port 3000",
    "test:backend": "node scripts/test-backend.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
